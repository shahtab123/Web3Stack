DATABASE_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require

# Canonical URL for SEO, Open Graph, and sitemap (required in production)
# Use your live domain after Cloudflare + Vercel DNS setup (https://...)
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Optional: Cloudflare in front of Vercel — see docs/cloudflare-setup.md
# (no extra env vars required; configure DNS + SSL in Cloudflare dashboard)

# Submission form email (SpaceMail / SMTP) — required for /submit form delivery
SMTP_HOST=mail.spacemail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=contact@hiddenai.cc
SMTP_PASSWORD=
SUBMIT_TO_EMAIL=contact@hiddenai.cc
SUBMIT_FROM_EMAIL=contact@hiddenai.cc
